# Public (safe to commit) — used by Vite at build time.
# Real values live in Lovable Cloud project secrets — never paste real keys here.
VITE_SUPABASE_URL="https://<your-project-ref>.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="<publishable-anon-key>"
VITE_SUPABASE_PROJECT_ID="<your-project-ref>"

# Server-only (do NOT commit real values). Stored as backend secrets.
# SUPABASE_URL="..."
# SUPABASE_PUBLISHABLE_KEY="..."
# SUPABASE_SERVICE_ROLE_KEY="..."   # server-only, bypasses RLS
# FOUNDER_ADMIN_EMAIL="..."
# LOVABLE_API_KEY="..."             # auto-provisioned by Lovable
